      </column>
      <column caption='Duration' datatype='integer' name='[Calculation_1596244660321185798]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Calculation_1596244660320272388], [Calculation_1596244660320419845])' />
      </column>
      <column caption='Building' datatype='string' name='[Rental Property - Split 11]' role='dimension' type='nominal' user:SplitFieldIndex='11' user:SplitFieldOrigin='[federated.1edl2mt0jkvoek1c7jq9m1fkzcqa].[Rental Property]'>
        <calculation class='tableau' formula='TRIM( SPLIT( [Rental Property], &quot;-&quot;, 2 ) )' />
