      </column>
      <column caption='Floor' datatype='string' name='[Calculation_1596244660312674306]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([Rental Property - Split 1],1)=&quot;1&quot; then &quot;First Floor&quot; ELSE &quot;Second Floor&quot; END' />
      </column>
      <column caption='Discount %' datatype='real' name='[Calculation_1596244660318081027]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Discount])/SUM([Rent])' />
      </column>
      <column aggregation='Count' caption='Start Date' datatype='date' datatype-customized='true' name='[Calculation_1596244660320272388]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATEPARSE ( &quot;dd-MMM-yyyy&quot;, [Start]+&quot;-&quot;+&quot;2025&quot; )) ' />
